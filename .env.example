# Copia este archivo como .env y llena los valores

# Base de datos PostgreSQL (Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/polla_mundialista?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/polla_mundialista?sslmode=require"

# Clave secreta para JWT (genera una con: openssl rand -base64 32)
JWT_SECRET="cambia-esto-por-una-clave-segura-aleatoria"

# Solo para Neon (serverless): dejar igual que DATABASE_URL pero con ?pgbouncer=true
# DATABASE_URL="postgresql://...?sslmode=require&pgbouncer=true"
